# ─────────────────────────────────────────────
#  UMUM
# ─────────────────────────────────────────────
alias c='clear'
alias q='exit'
alias ls='eza --icons'
alias tree='eza --tree --icons'
alias rm='rm -i --preserve-root'
alias cp='cp -i'
alias mv='mv -i'
alias nano='fresh'
alias copy='wl-copy'
alias zshrc='${=EDITOR} ${ZDOTDIR:-$HOME}/.zshrc'
alias zshrc-alias='${=EDITOR} ${ZDOTDIR:-$HOME}/.zshrc-alias'


# ─────────────────────────────────────────────
#  DOCKER
# ─────────────────────────────────────────────
alias d='docker'
alias dc='docker compose'
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs -f'
alias dps='docker ps'


# ─────────────────────────────────────────────
#  MOUNT & NAVIGASI
# ─────────────────────────────────────────────
alias mount-hdd1='sudo mount -t ext4 UUID=3c169c1a-3b2a-49fe-a281-31dc51dcb482 /mnt/hdd1'
alias mount-hdd2='sudo mount -t ext4 UUID=04e0012d-a77b-4511-945d-fabd0d8a22f6 /mnt/hdd2'

# /dev/sda2
alias mount-disk-d='sudo mount -t ntfs3 \
-o rw,uid=1000,gid=1000,windows_names,noatime \
UUID=40AA28F357FDB4AE /mnt/windows/disk-d'

# /dev/sdc4
alias mount-disk-c='sudo mount -t ntfs3 \
-o rw,uid=1000,gid=1000,windows_names,noatime \
UUID=D4B4B859B4B83FB2 /mnt/windows/disk-c'

alias cdarr='cd /mnt/hdd1/data'
alias cdmich='cd /home/irba/server/immich'

mnt-cdarr() {
  mount-hdd1 2>/dev/null
  cdarr
}


# ─────────────────────────────────────────────
#  WARP VPN
# ─────────────────────────────────────────────
alias wcc='warp-cli connect'
alias wcd='warp-cli disconnect'
alias wcs='warp-cli status'


# ─────────────────────────────────────────────
#  IMMICH
# ─────────────────────────────────────────────
immich-sync() {
  local SRC="/home/irba/server/immich/images/library/admin"
  local DEST="/home/irba/Pictures/phone-photos"
  local SS="$DEST/screenshot"

  mkdir -p "$DEST" "$SS"

  echo "🔄 Syncing photos..."
  find "$SRC" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" \) \
    -exec ln -s {} "$DEST"/ 2>/dev/null \;

  echo "🧹 Sorting screenshots..."
  find "$DEST" -type l -iname "*screenshot*" \
    -exec mv -t "$SS" {} + 2>/dev/null

  echo "✅ Done!"
}


# ─────────────────────────────────────────────
#  SISTEM & SNAPSHOT
# ─────────────────────────────────────────────
syu() {
  sudo snapper create --description "pre pacman -Syu" &&
  sudo pacman -Syu
}

snap() {
  local desc="${1:-manual snapshot}"
  local time
  time=$(date +"%H:%M:%S")

  if sudo snapper create --description "$desc"; then
    echo "✅ [$time] Snapshot created successfully: $desc"
  else
    echo "❌ [$time] Snapshot creation failed"
  fi
}


# ─────────────────────────────────────────────
#  GIT PUSH
# ─────────────────────────────────────────────
_git_push_repo() {
  local label="$1"
  local dir="$2"
  local auto="${3:-no}"   # "auto" = skip semua konfirmasi

  cd "$dir" || { echo "❌ Gagal masuk ke $dir"; return 1; }

  echo ""
  echo "📁 Repo   : $label"
  echo "📂 Dir    : $(pwd)"
  echo ""
  git status --short

  if [[ "$auto" != "auto" ]]; then
    echo ""
    echo -n "❓ Lanjut git add & commit? [Y/n] "
    read -r confirm
    [[ "$confirm" =~ ^[Nn]$ ]] && { echo "⛔ Dibatalkan."; return 0; }
  fi

  echo ""
  echo -n "📝 Commit message [default: 'commit']: "
  if [[ "$auto" == "auto" ]]; then
    msg="commit"
    echo "$msg (auto)"
  else
    read -r msg
    msg="${msg:-commit}"
  fi

  git add .
  git commit -m "$msg"

  if [[ "$auto" != "auto" ]]; then
    echo ""
    echo -n "🚀 Lanjut git push? [Y/n] "
    read -r push_confirm
    [[ "$push_confirm" =~ ^[Nn]$ ]] && { echo "⛔ Push dibatalkan."; return 0; }
  fi

  git push -u origin main
  echo ""
  echo "✅ Selesai push $label!"
}

alias git-push-dotfiles='_git_push_repo "Dotfiles"       "/home/irba/dotfiles"'
alias git-push-obsidian='_git_push_repo "Obsidian Vault" "/home/irba/Documents/obsidianVault/myVault"'
alias git-push-backup='_git_push_repo  "Backup"          "/home/irba/backup-git"'

gitp() {
  echo ""
  echo "🗂  Pilih repo yang mau di-push:"
  echo "  1) All  (dengan konfirmasi)"
  echo "  2) All  (langsung push, tanpa konfirmasi)"
  echo "  3) Dotfiles"
  echo "  4) Obsidian Vault"
  echo "  5) Backup"
  echo ""
  echo -n "Pilihan [1-5]: "
  read -r choice

  case "$choice" in
    1)
      _git_push_repo "Dotfiles"       "/home/irba/dotfiles"
      _git_push_repo "Obsidian Vault" "/home/irba/Documents/obsidianVault/myVault"
      _git_push_repo "Backup"         "/home/irba/backup-git"
      ;;
    2)
      _git_push_repo "Dotfiles"       "/home/irba/dotfiles"                          auto
      _git_push_repo "Obsidian Vault" "/home/irba/Documents/obsidianVault/myVault"   auto
      _git_push_repo "Backup"         "/home/irba/backup-git"                        auto
      ;;
    3) _git_push_repo "Dotfiles"       "/home/irba/dotfiles" ;;
    4) _git_push_repo "Obsidian Vault" "/home/irba/Documents/obsidianVault/myVault" ;;
    5) _git_push_repo "Backup"         "/home/irba/backup-git" ;;
    *) echo "❌ Pilihan tidak valid." ;;
  esac
}

# ─────────────────────────────────────────────
#  HOME BACKUP
# ─────────────────────────────────────────────

alias backup-home='sudo ~/backup-git/tiered-backup.sh'
alias backup-full='sudo ~/backup-git/tiered-backup.sh -f'
alias backup-ph='sudo ~/backup-git/tiered-backup.sh -p'
alias backup-dry='sudo ~/backup-git/tiered-backup.sh -d'

