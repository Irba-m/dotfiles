  echo "  syu             → snapshot snapper dulu, lalu pacman -Syu"
  echo "  snap [desc]     → buat snapshot manual (default: 'manual snapshot')"

  echo ""
  echo "🚀 GIT PUSH"
  echo "  gitp                → menu interaktif pilih repo yang mau di-push"
  echo "  git-push-dotfiles   → push repo Dotfiles"
  echo "  git-push-obsidian   → push repo Obsidian Vault"
  echo "  git-push-backup     → push repo Backup"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
}
