  echo ""
  echo "🔧 UMUM"
  echo "  c               → clear terminal"
  echo "  q               → exit terminal"
  echo "  ls              → eza dengan icons"
  echo "  tree            → eza tree view dengan icons"
  echo "  rm / cp / mv    → dengan konfirmasi interaktif (-i)"
  echo "  nano            → fresh (editor pengganti nano)"
  echo "  copy            → wl-copy (clipboard Wayland)"
  echo "  zshrc           → buka file .zshrc di editor"

  echo ""
  echo "🐳 DOCKER"
  echo "  d               → docker"
  echo "  dc              → docker compose"
  echo "  dcu             → docker compose up -d"
  echo "  dcd             → docker compose down"
  echo "  dcl             → docker compose logs -f"
  echo "  dps             → docker ps"

  echo ""
  echo "💾 MOUNT & NAVIGASI"
  echo "  mount-hdd1      → mount HDD1 (NTFS, UUID=0DBF...)"
  echo "  mount-hdd2      → mount HDD2 (NTFS, UUID=C84C...)"
  echo "  cdarr           → cd ke /mnt/hdd1/data"
  echo "  cdmich          → cd ke /home/irba/server/immich"
  echo "  mnt-cdarr       → mount HDD1 lalu langsung cd ke sana"

  echo ""
  echo "🌐 WARP VPN"
  echo "  wcc             → warp-cli connect"
  echo "  wcd             → warp-cli disconnect"
  echo "  wcs             → warp-cli status"

  echo ""
  echo "📸 IMMICH"
  echo "  immich-sync     → sync foto dari immich ke ~/Pictures/phone-photos"
  echo "                    + auto sortir screenshot ke subfolder"

  echo ""
